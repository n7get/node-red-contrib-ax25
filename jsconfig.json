{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["lib/*"],
      "@nodes/*": ["nodes/*"],
      "@test/*": ["test/*"],
      "@helpers/*": ["test/helpers/*"],
      "@fixtures/*": ["test/fixtures/*"]
    }
  },
  "include": [
    "nodes/**/*",
    "lib/**/*",
    "test/**/*",
    "examples/**/*"
  ],
  "exclude": [
    "node_modules",
    ".git",
    "dist",
    "build"
  ]
}
